# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# Vite exposes only variables prefixed with VITE_ to the browser.

# Anthropic (Claude) — server-side / tooling only if used; do not expose in client bundles
VITE_ANTHROPIC_API_KEY=

# Mapbox (public token is ok in frontend; still avoid committing real tokens to git)
VITE_MAPBOX_TOKEN=
VITE_MAPBOX_STYLE=mapbox://styles/your-username/your-style-id

# LMP / V1 backend
VITE_API_URL=https://gridalpha-production.up.railway.app
VITE_BACKEND_URL=https://gridalpha-production.up.railway.app

# News API (separate Railway service)
VITE_NEWS_API_URL=https://gridalpha-v2-production.up.railway.app

# Tomorrow.io — https://app.tomorrow.io/development/keys
VITE_TOMORROW_API_KEY=

# EIA — https://www.eia.gov/opendata/register.php
VITE_EIA_API_KEY=

# ElectricityMaps — https://api.electricitymap.org
VITE_ELECTRICITY_MAPS_KEY=

# ── FastAPI on Railway (server-side env vars — no VITE_ prefix) ─────────────
# Set these in Railway → Variables for the service running app.main:app
# EIA_API_KEY=
# TOMORROW_API_KEY=
# PJM_USERNAME=   # PJM Tools account (DataMiner API — ForgeRock SSO)
# PJM_PASSWORD=
# Optional: PJM_SSO_AUTH_URL=https://sso.pjm.com/access/authenticate
# Optional: PJM_SESSION_COOKIE_NAME=iPlanetDirectoryPro
# Optional: CORS_ORIGINS=https://your-preview.vercel.app,https://custom-domain.com
