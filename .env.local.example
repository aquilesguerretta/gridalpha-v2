# Anthropic API key — required for AI Assistant feature
# Get one at https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_key_here

# ─── FORGE Wave 4 — V2 backend wiring ───────────────────────────────

# Base URL for Cursor's V2 backend (Wave-5 canonical envelope routes).
# Defaults to the Railway production service when unset. Override when
# pointing the dev server at a local uvicorn or a staging environment.
# VITE_BACKEND_URL=http://localhost:8000

# Force every Wave-4 data hook to use its internal shape-matched mock
# producer instead of fetching from VITE_BACKEND_URL. Useful when the
# backend is unreachable (offline dev, demo machines without internet,
# or CI builds that shouldn't hit the network).
#
# Default is `false` (live mode). Set to `true` to flip the whole app
# into mock mode without touching code.
# VITE_MOCK_API=true
