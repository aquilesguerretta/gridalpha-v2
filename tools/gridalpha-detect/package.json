{
  "name": "@gridalpha/detect",
  "version": "0.1.0",
  "private": true,
  "description": "Static auditor for GridAlpha terminal anti-patterns. Encodes the detectable subset of .claude/skills/gridalpha-terminal/references/terminal-antipatterns.md into a CLI gate.",
  "type": "module",
  "bin": {
    "gridalpha-detect": "./bin/gridalpha-detect.mjs"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "self-check": "tsx src/index.ts ../../src --fast",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
